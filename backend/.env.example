# Variáveis de Ambiente — Backend Conversor MD
# NUNCA commite este arquivo em repositórios públicos (está no .gitignore)

# ====================================================
# CHAVE DA API DO GEMINI (Google AI Studio)
# Obtenha sua chave em: https://aistudio.google.com/apikey
# ====================================================
GEMINI_API_KEY=sua_chave_aqui

# ====================================================
# CONFIGURAÇÕES DO SERVIDOR
# ====================================================
PORT=3001
NODE_ENV=development

# ====================================================
# LIMITES DE ARQUIVO
# ====================================================
MAX_FILE_SIZE_MB=50
MAX_CHARS_PER_MD_FILE=5000
