{
  "name": "conversor-md-backend",
  "version": "1.0.0",
  "description": "Backend do Conversor MD — Transcrição fiel de documentos para Markdown com Gemini 1.5 Pro",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --verbose",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/generative-ai": "^0.21.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "multer": "^2.2.0",
    "openai": "^6.44.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "conversor",
    "markdown",
    "gemini",
    "medical",
    "pdf",
    "ocr"
  ],
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true,
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "utils/**/*.js",
      "services/**/*.js",
      "routes/**/*.js",
      "prompts/**/*.js"
    ]
  }
}
